<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Professional Email Campaign Manager - Send bulk emails with ease">
    <meta name="theme-color" content="#003087">
    <title>Email Campaign Manager - Trugydex</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-blue: #003087;
            --primary-green: #2E7D32;
            --secondary-blue: #1a4a8f;
            --light-blue: #f0f4f9;
            --light-green: #f1f8f4;
            --text-primary: #1a1a1a;
            --text-secondary: #666666;
            --border-color: #e0e0e0;
            --success-color: #2E7D32;
            --error-color: #ef4444;
        }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: #f8f9fa;
            color: var(--text-primary);
            line-height: 1.6;
        }
        
        /* Login Screen */
        .login-container {
            min-height: 100vh;
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        
        .login-card {
            background: white;
            border-radius: 16px;
            padding: 3rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0, 48, 135, 0.2);
        }
        
        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        
        .login-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-blue);
            margin-bottom: 0.5rem;
        }
        
        .login-header p {
            font-size: 14px;
            color: var(--text-secondary);
        }
        
        .login-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 2rem;
            border-bottom: 2px solid var(--border-color);
        }
        
        .login-tab-btn {
            flex: 1;
            padding: 12px;
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
        }
        
        .login-tab-btn.active {
            color: var(--primary-blue);
            border-bottom-color: var(--primary-blue);
        }
        
        .login-form {
            display: none;
        }
        
        .login-form.active {
            display: block;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--primary-blue);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        input[type="text"],
        input[type="email"],
        input[type="password"],
        textarea,
        select {
            width: 100%;
            padding: 12px 14px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            transition: all 0.3s ease;
            background: white;
        }
        
        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 4px rgba(0, 48, 135, 0.1);
            background: var(--light-blue);
        }
        
        textarea {
            resize: vertical;
            min-height: 120px;
        }
        
        input[type="file"] {
            padding: 10px;
        }
        
        .button-login {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }
        
        .button-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 48, 135, 0.3);
        }
        
        .demo-users {
            background: var(--light-green);
            border-left: 4px solid var(--primary-green);
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 2rem;
            font-size: 12px;
        }
        
        .demo-users strong {
            display: block;
            color: var(--primary-green);
            margin-bottom: 6px;
            font-weight: 700;
        }
        
        .demo-user {
            margin: 6px 0;
            cursor: pointer;
            padding: 4px;
            border-radius: 4px;
            transition: all 0.2s;
        }
        
        .demo-user:hover {
            background: white;
        }
        
        /* Dashboard */
        .dashboard {
            background: white;
            min-height: 100vh;
            display: none;
        }
        
        .dashboard.active {
            display: block;
        }
        
        .top-bar {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            color: white;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .top-bar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .top-bar-logo {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 700;
        }
        
        .top-bar-user {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(46, 125, 50, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }
        
        .user-info {
            font-size: 13px;
        }
        
        .user-info .name {
            font-weight: 600;
        }
        
        .user-info .role {
            font-size: 11px;
            opacity: 0.8;
        }
        
        .logout-btn {
            padding: 8px 16px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 2px solid white;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 600;
            transition: all 0.3s;
        }
        
        .logout-btn:hover {
            background: white;
            color: var(--primary-blue);
            border-color: white;
        }
        
        .header {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            color: white;
            padding: 2.5rem 2rem;
            position: relative;
            overflow: hidden;
        }
        
        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(46, 125, 50, 0.1);
            border-radius: 50%;
            z-index: 1;
        }
        
        .header-content {
            position: relative;
            z-index: 2;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            line-height: 1.2;
        }
        
        .header-text p {
            font-size: 15px;
            opacity: 0.95;
            max-width: 500px;
        }
        
        .container {
            padding: 0 2rem;
            max-width: 1400px;
            margin: 0 auto;
            padding-bottom: 2rem;
        }
        
        .nav-tabs {
            display: flex;
            gap: 0;
            border-bottom: 2px solid var(--border-color);
            margin-bottom: 2rem;
            background: white;
            margin: 0 -2rem 2rem -2rem;
            padding: 0 2rem;
            overflow-x: auto;
        }
        
        .nav-tab {
            padding: 16px 24px;
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 15px;
            font-weight: 600;
            color: var(--text-secondary);
            border-bottom: 3px solid transparent;
            transition: all 0.3s ease;
            white-space: nowrap;
        }
        
        .nav-tab:hover {
            color: var(--primary-blue);
        }
        
        .nav-tab.active {
            color: var(--primary-blue);
            border-bottom-color: var(--primary-blue);
        }
        
        .tab-panel {
            display: none;
        }
        
        .tab-panel.active {
            display: block;
        }
        
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }
        
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .card {
            background: white;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 1.5rem;
            color: var(--primary-blue);
            border-bottom: 2px solid var(--light-blue);
            padding-bottom: 1rem;
        }
        
        .stat-card {
            background: linear-gradient(135deg, var(--light-blue) 0%, var(--light-green) 100%);
            border-radius: 12px;
            padding: 1.5rem;
            border: 2px solid var(--border-color);
            text-align: center;
        }
        
        .stat-label {
            font-size: 12px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 12px;
            font-weight: 700;
        }
        
        .stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 36px;
            font-weight: 700;
            color: var(--primary-blue);
        }
        
        .alert {
            padding: 14px 16px;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 13px;
            border-left: 4px solid;
        }
        
        .alert-info {
            background: #eff6ff;
            color: var(--primary-blue);
            border-color: var(--primary-blue);
        }
        
        .alert strong {
            font-weight: 700;
        }
        
        /* Upload Zone */
        .upload-zone {
            border: 3px dashed var(--primary-blue);
            border-radius: 12px;
            padding: 3rem 2rem;
            text-align: center;
            background: var(--light-blue);
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 1.5rem;
        }
        
        .upload-zone:hover,
        .upload-zone.dragover {
            background: linear-gradient(135deg, var(--light-blue) 0%, var(--light-green) 100%);
            border-color: var(--primary-green);
            transform: scale(1.02);
        }
        
        .upload-zone-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .upload-zone-text h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--primary-blue);
        }
        
        .upload-zone-text p {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 1rem;
        }
        
        .upload-zone-formats {
            display: inline-block;
            background: white;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 12px;
            color: var(--primary-green);
            font-weight: 600;
        }
        
        /* Preview Table */
        .preview-table-container {
            background: white;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            overflow: hidden;
            margin-bottom: 1.5rem;
            max-height: 400px;
            overflow-y: auto;
        }
        
        .table-header {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            color: white;
            padding: 1rem 1.5rem;
            font-weight: 600;
            font-size: 14px;
        }
        
        .preview-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        
        .preview-table thead {
            background: var(--light-blue);
            border-bottom: 2px solid var(--border-color);
            position: sticky;
            top: 0;
        }
        
        .preview-table th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 700;
            color: var(--primary-blue);
        }
        
        .preview-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-color);
        }
        
        .preview-table tbody tr:hover {
            background: var(--light-blue);
        }
        
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        
        .status-valid {
            background: #d1fae5;
            color: var(--primary-green);
        }
        
        .status-invalid {
            background: #fee2e2;
            color: var(--error-color);
        }
        
        .button {
            padding: 12px 24px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            background: white;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.3s ease;
            color: var(--text-primary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .button:hover {
            background: var(--light-blue);
            border-color: var(--primary-blue);
        }
        
        .button-primary {
            background: linear-gradient(135deg, var(--primary-blue) 0%, var(--secondary-blue) 100%);
            color: white;
            border: none;
        }
        
        .button-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0, 48, 135, 0.3);
        }
        
        .button-success {
            background: linear-gradient(135deg, var(--primary-green) 0%, #1b5e20 100%);
            color: white;
            border: none;
        }
        
        .button-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(46, 125, 50, 0.3);
        }
        
        .button-danger {
            background: var(--error-color);
            color: white;
            border: none;
        }
        
        .recent-item {
            margin-bottom: 12px;
            padding: 12px;
            background: var(--light-blue);
            border-radius: 8px;
            border-left: 4px solid var(--primary-green);
        }
        
        .recent-item strong {
            font-size: 14px;
            color: var(--primary-blue);
            display: block;
            margin-bottom: 4px;
        }
        
        .recent-item p {
            font-size: 11px;
            color: var(--text-secondary);
            margin: 2px 0;
        }
        
        .file-info {
            background: var(--light-green);
            border-left: 4px solid var(--primary-green);
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 1.5rem;
            display: none;
        }
        
        .file-info.show {
            display: block;
        }
        
        .file-info strong {
            color: var(--primary-green);
            display: block;
            margin-bottom: 4px;
            font-weight: 700;
        }
        
        .stats-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            padding: 1rem;
            background: var(--light-blue);
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-item-value {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--primary-blue);
        }
        
        .stat-item-label {
            font-size: 11px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            margin-top: 4px;
        }
        
        @media (max-width: 1024px) {
            .grid-2 {
                grid-template-columns: 1fr;
            }
            .grid-3 {
                grid-template-columns: repeat(2, 1fr);
            }
            .header-text h1 {
                font-size: 2rem;
            }
        }
        

        /* Attachment Styles */
        .attachment-zone {
            border: 2px dashed var(--border-color);
            border-radius: 10px;
            padding: 1.5rem;
            text-align: center;
            background: #fafafa;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 1rem;
        }

        .attachment-zone:hover,
        .attachment-zone.dragover {
            background: var(--light-blue);
            border-color: var(--primary-blue);
        }

        .attachment-zone-icon {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .attachment-zone p {
            font-size: 13px;
            color: var(--text-secondary);
            margin: 0;
        }

        .attachment-zone strong {
            color: var(--primary-blue);
            font-size: 14px;
        }

        .attachment-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 1rem;
        }

        .attachment-item {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--light-blue);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
        }

        .attachment-item-icon {
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .attachment-item-info {
            flex: 1;
            overflow: hidden;
        }

        .attachment-item-name {
            font-weight: 600;
            color: var(--text-primary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .attachment-item-size {
            font-size: 11px;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        .attachment-remove-btn {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.1rem;
            color: var(--error-color);
            flex-shrink: 0;
            padding: 2px 6px;
            border-radius: 4px;
            transition: background 0.2s;
        }

        .attachment-remove-btn:hover {
            background: #fee2e2;
        }

        .attachment-summary {
            font-size: 12px;
            color: var(--text-secondary);
            padding: 6px 10px;
            background: white;
            border-radius: 6px;
            border: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .attachment-summary span {
            color: var(--primary-green);
            font-weight: 700;
        }

        .attachment-formats {
            font-size: 11px;
            color: var(--text-secondary);
            margin-top: 6px;
        }

        @media (max-width: 640px) {
            .grid-3 {
                grid-template-columns: 1fr;
            }
            .login-card {
                padding: 2rem;
            }
            .header {
                padding: 1.5rem 1rem;
            }
            .top-bar {
                flex-direction: column;
                gap: 1rem;
            }
            .top-bar-left,
            .top-bar-user {
                width: 100%;
                justify-content: space-between;
            }
        }
    </style>
</head>
<body>
    <!-- Login Screen -->
    <div id="loginScreen" class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h1 style="font-size:16px; color: var(--text-secondary); font-family: 'DM Sans', sans-serif; font-weight:500; letter-spacing:1px;">EMAIL CAMPAIGN MANAGER</h1>
            </div>
            
            <div style="text-align:center; margin-bottom: 2rem;">
                <img src="data:image/png;base64," alt="Trugydex Logo" style="max-width: 220px; width: 100%; height: auto;" />
            </div>
            
            <div class="login-tabs">
                <button class="login-tab-btn active" onclick="switchLoginTab('login', this)">Login</button>
                <button class="login-tab-btn" onclick="switchLoginTab('signup', this)">Signup</button>
            </div>
            
            <!-- Login Form -->
            <form class="login-form active" id="loginForm" onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" id="loginEmail" placeholder="your@email.com" required />
                </div>
                
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" id="loginPassword" placeholder="••••••••" required />
                </div>
                
                <button type="submit" class="button-login">Login</button>
            </form>
            
            <!-- Signup Form -->
            <form class="login-form" id="signupForm" onsubmit="handleSignup(event)">
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" id="signupName" placeholder="Your Full Name" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <input type="email" id="signupEmail" placeholder="your@email.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input type="password" id="signupPassword" placeholder="Min 6 characters" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" id="signupConfirm" placeholder="Confirm password" required />
                </div>
                <button type="submit" class="button-login">Create Account</button>
            </form>
        </div>
    </div>
    
    <!-- Dashboard -->
    <div id="dashboardScreen" class="dashboard">
        <!-- Top Bar -->
        <div class="top-bar">
            <div class="top-bar-left">
                <div class="top-bar-logo"><img src="data:image/png;base64," alt="Trugydex" style="height:36px; width:auto; vertical-align:middle; filter: brightness(0) invert(1);" /></div>
            </div>
            <div class="top-bar-user">
                <div class="user-avatar" id="userInitials">A</div>
                <div class="user-info">
                    <div class="name" id="currentUserName">Admin</div>
                    <div class="role" id="currentUserRole">Administrator</div>
                </div>
                <button class="logout-btn" onclick="handleLogout()">Logout</button>
            </div>
        </div>
        
        <!-- Header -->
        <div class="header">
            <div class="header-content">
                <div class="header-text">
                    <h1>Welcome to Campaign Manager</h1>
                    <p>Upload email lists, send bulk campaigns, and track results</p>
                </div>
            </div>
        </div>
        
        <!-- Content -->
        <div class="container">
            <div class="nav-tabs">
                <button class="nav-tab active" onclick="switchTab('dashboard')">Dashboard</button>
                <button class="nav-tab" onclick="switchTab('upload')">📥 Bulk Upload</button>
                <button class="nav-tab" onclick="switchTab('compose')">Send Email</button>
